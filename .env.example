# Copy to .env and fill in. .env is gitignored.

# Sending (required). App password needs 2-step verification on the account.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Subscriber list (optional). A Google Sheet with one column headed "email",
# shared with the service account in GOOGLE_CREDS_PATH as Editor.
# Leave blank to send to GMAIL_USER only (test mode).
PIGEON_SHEET_ID=
GOOGLE_CREDS_PATH=./google-creds.json

# Met, AIC, Cleveland, and SMK are keyless. Two more museums unlock with
# free keys (api.data.gov and harvardartmuseums.org/collections/api).
# Rijksmuseum was dropped 2026-06: their classic API is gone (HTTP 410) and
# the Linked Art replacement needs a chain of fetches per artwork.
SI_API_KEY=
HARVARD_API_KEY=
